{
  "manifest_version": 3,
  "name": "Trigger Code Snippets",
  "version": "1.2.0",
  "description": "Save and trigger JavaScript snippets via keyboard shortcuts, context menus, or the toolbar popup.",
  "permissions": [
    "activeTab",
    "scripting",
    "contextMenus",
    "storage",
    "debugger",
    "tabs",
    "tabGroups",
    "cookies",
    "webNavigation",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "clipboardRead",
    "clipboardWrite",
    "downloads",
    "history",
    "bookmarks",
    "sessions",
    "notifications",
    "alarms",
    "idle",
    "management",
    "browsingData",
    "offscreen",
    "pageCapture",
    "tabCapture",
    "system.display",
    "privacy",
    "contentSettings",
    "accessibilityFeatures.read",
    "accessibilityFeatures.modify"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Trigger Code Snippets"
  },
  "options_page": "manager/manager.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
